// Prisma schema for the Zagvar online shop directory.
// Generated from the source-of-truth DBML.
//
// Conventions:
//   - Models are PascalCase and mapped to snake_case tables via @@map.
//   - Fields are camelCase and mapped to snake_case columns via @map.
//   - UUID primary keys are DB-generated with gen_random_uuid().
//   - Timestamps use timestamptz(6) (UTC-aware). The DBML says `timestamp`;
//     timestamptz is the safer default for a real deployment.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model SuperAdmin {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String    @unique @db.VarChar
  passwordHash String    @map("password_hash") @db.VarChar
  name         String?   @db.VarChar
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime? @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("super_admins")
}

model Shop {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @db.VarChar
  slug        String   @unique @db.VarChar
  description String?  @db.Text
  address     String?  @db.VarChar
  latitude    Decimal? @db.Decimal(10, 7)
  longitude   Decimal? @db.Decimal(10, 7)
  logoUrl     String?  @map("logo_url") @db.VarChar
  coverUrl    String?  @map("cover_url") @db.VarChar
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime? @updatedAt @map("updated_at") @db.Timestamptz(6)

  admins   ShopAdmin[]
  contacts ShopContact[]
  socials  ShopSocial[]
  products Product[]

  @@map("shops")
}

model ShopAdmin {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shopId       String    @map("shop_id") @db.Uuid
  email        String    @unique @db.VarChar
  passwordHash String    @map("password_hash") @db.VarChar
  name         String?   @db.VarChar
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime? @updatedAt @map("updated_at") @db.Timestamptz(6)

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
  @@map("shop_admins")
}

model ShopContact {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shopId    String   @map("shop_id") @db.Uuid
  type      String   @db.VarChar // phone, email, whatsapp, etc.
  value     String   @db.VarChar
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
  @@map("shop_contacts")
}

model ShopSocial {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shopId    String   @map("shop_id") @db.Uuid
  platform  String   @db.VarChar // facebook, instagram, telegram, etc.
  url       String   @db.VarChar
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
  @@map("shop_socials")
}

model Category {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @db.VarChar
  slug      String   @unique @db.VarChar
  position  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  subcategories Subcategory[]
  products      Product[]    @relation("ProductCategories")

  @@map("categories")
}

model Subcategory {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  categoryId String   @map("category_id") @db.Uuid
  name       String   @db.VarChar
  slug       String   @db.VarChar
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  category Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  products Product[] @relation("ProductSubcategories")

  @@unique([categoryId, slug])
  @@map("subcategories")
}

model Product {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shopId      String    @map("shop_id") @db.Uuid
  name        String    @db.VarChar
  slug        String    @db.VarChar
  description String?   @db.Text
  price       Decimal   @db.Decimal(12, 2)
  currency    String?   @default("USD") @db.VarChar
  size        String[]  @default([]) @db.VarChar
  color       String[]  @default([]) @db.VarChar
  isActive    Boolean   @default(true) @map("is_active")
  clickCount  Int       @default(0) @map("click_count")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime? @updatedAt @map("updated_at") @db.Timestamptz(6)

  shop          Shop           @relation(fields: [shopId], references: [id], onDelete: Cascade)
  // A product can belong to many categories and many subcategories.
  categories    Category[]     @relation("ProductCategories")
  subcategories Subcategory[]  @relation("ProductSubcategories")
  images        ProductImage[]

  @@unique([shopId, slug])
  @@map("products")
}

model Banner {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title     String?   @db.VarChar
  imageUrl  String    @map("image_url") @db.VarChar
  linkUrl   String?   @map("link_url") @db.VarChar
  isActive  Boolean   @default(true) @map("is_active")
  position  Int       @default(0)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime? @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("banners")
}

model ProductImage {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId String   @map("product_id") @db.Uuid
  url       String   @db.VarChar
  position  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_images")
}

# ----------------------------------------------------------------------------
# Production environment for zagvar-backend.
# Copy to /opt/zagvar/app/.env on the server and fill in the real secrets.
# This file is the TEMPLATE — never commit the filled-in .env.
# ----------------------------------------------------------------------------
NODE_ENV=production
PORT=3010

# CORS allowlist for credentialed (cookie) requests. Must list every browser
# origin that calls the API (storefront + admin once it exists).
CORS_ORIGINS=https://zagvar.com,https://admin.zagvar.com

# Auth cookies. SECURE=true requires HTTPS (we terminate TLS at nginx and set
# `trust proxy` in main.ts). SAMESITE=none lets the admin on a different
# subdomain send the cookie; DOMAIN scopes it across *.zagvar.com.
COOKIE_SECURE=true
COOKIE_SAMESITE=none
COOKIE_DOMAIN=.zagvar.com

# PostgreSQL runs NATIVELY on the host. The app container reaches it via the
# docker host-gateway alias. Replace <DB_PASSWORD> with the generated password.
DATABASE_URL=postgresql://zagvar:<DB_PASSWORD>@host.docker.internal:5432/zagvar?schema=public

# JWT secrets — generate distinct random strings (>=16 chars), e.g.
#   openssl rand -base64 48
JWT_SECRET=<GENERATE_ME>
JWT_REFRESH_SECRET=<GENERATE_ME_DIFFERENT>
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Super-admin bootstrap (used once by `npm run db:seed`).
SEED_SUPER_ADMIN_EMAIL=admin@zagvar.com
SEED_SUPER_ADMIN_PASSWORD=<STRONG_PASSWORD>
SEED_SUPER_ADMIN_NAME=Super Admin

# ----------------------------------------------------------------------------
# Cloudflare R2 (optional — only needed for product/shop image uploads).
# Leave blank to skip; seed data uses picsum.photos URLs.
# ----------------------------------------------------------------------------
CF_ACCOUNT_ID=
CF_ENDPOINT=
CF_BUCKET_NAME=
CF_R2_ACCESS_KEY_ID=
CF_R2_SECRET_ACCESS_KEY=
CF_FOLDER=uploads
CF_PUBLIC_BASE_URL=

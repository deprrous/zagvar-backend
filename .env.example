# ----------------------------------------------------------------------------
# Core
# ----------------------------------------------------------------------------
NODE_ENV=development
PORT=3010

# CORS allowlist for credentialed (cookie) requests, comma-separated. Leave
# blank to reflect the request origin (dev only). Set to the admin + storefront
# origins in production, e.g. https://admin.zagvar.com,https://zagvar.com
CORS_ORIGINS=
# Auth cookie tuning. SECURE must be true in production (HTTPS); SAMESITE must
# be "none" (with SECURE=true) if the admin is on a different site than the API.
COOKIE_SAMESITE=lax
COOKIE_SECURE=
# COOKIE_DOMAIN=

# PostgreSQL connection string (Prisma + pg driver adapter).
# For local Docker Compose use:
#   postgresql://zagvar:zagvar@localhost:5432/zagvar?schema=public
DATABASE_URL="postgresql://zagvar:zagvar@localhost:5432/zagvar?schema=public"

# ----------------------------------------------------------------------------
# JWT (use long random strings; min 16 chars each, distinct values)
# ----------------------------------------------------------------------------
JWT_SECRET=change-me-access-secret-please
JWT_REFRESH_SECRET=change-me-refresh-secret-please
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ----------------------------------------------------------------------------
# Seed (used by `npm run db:seed`)
# ----------------------------------------------------------------------------
SEED_SUPER_ADMIN_EMAIL=superadmin@zagvar.local
SEED_SUPER_ADMIN_PASSWORD=ChangeMe123!
SEED_SUPER_ADMIN_NAME=Super Admin

# ----------------------------------------------------------------------------
# Cloudflare R2 storage (optional — only needed for product image uploads)
# ----------------------------------------------------------------------------
CF_ACCOUNT_ID=
CF_ENDPOINT=
CF_BUCKET_NAME=
CF_R2_ACCESS_KEY_ID=
CF_R2_SECRET_ACCESS_KEY=
CF_FOLDER=uploads
# Public base URL/CDN for stored objects (custom domain). When unset, image
# URLs fall back to the raw R2 endpoint form (only works for public buckets).
CF_PUBLIC_BASE_URL=
